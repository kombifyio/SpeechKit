<?xml version="1.0" encoding="utf-8"?>
<!-- SpeechKit Assist panel: shows LLM answer in place of keyboard -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/speechkit_assist_panel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone"
    android:background="?android:attr/colorBackground"
    android:padding="12dp">

    <!-- Question -->
    <TextView
        android:id="@+id/speechkit_assist_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="?android:attr/textColorSecondary"
        android:textStyle="italic"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="8dp" />

    <!-- Answer (scrollable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxHeight="200dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/speechkit_assist_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="?android:attr/textColorPrimary"
            android:lineSpacingMultiplier="1.3" />
    </ScrollView>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="4dp">

        <Button
            android:id="@+id/speechkit_assist_insert"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/speechkit_assist_insert"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            style="?android:attr/buttonBarPositiveButtonStyle" />

        <Button
            android:id="@+id/speechkit_assist_copy"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/speechkit_assist_copy"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            style="?android:attr/buttonBarNeutralButtonStyle" />

        <Button
            android:id="@+id/speechkit_assist_close"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/speechkit_assist_close"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            style="?android:attr/buttonBarNegativeButtonStyle" />
    </LinearLayout>

</LinearLayout>
